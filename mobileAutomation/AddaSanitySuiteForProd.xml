        <listener class-name="listener.AnnotationTransformer"/>
        <listener class-name="org.testng.reporters.XMLReporter"/>
    </listeners>

    <test name="Device">
        <parameter name="port" value="4723"/>
<!--     Mention your connected device udid     -->
        <parameter name="udid" value="ZD222GXGN9"/>
        <classes>
            <class name="test_scripts.LoginTest"/>
            <class name="test_scripts.LogoutTest"/>
            <class name="test_scripts.PDPTest"/>
            <class name="test_scripts.PaymentTest"/>
            <class name="test_scripts.HomeTest"/>
            <class name="test_scripts.ReferAndEarnTest"/>
            <class name="test_scripts.TestPass"/>
            <class name="test_scripts.CommunityPost"/>
        </classes>
